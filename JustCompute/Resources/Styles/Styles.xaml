    <Style Class="FlyoutItemLayoutStyle"
           TargetType="Layout"
           ApplyToDerivedTypes="True">
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor"
                                    Value="{AppThemeBinding Light={StaticResource LightPrimary}, Dark={StaticResource DarkSurface}}" />
                            <Setter TargetName="FlyoutItemLabel"
                                    Property="Label.TextColor"
                                    Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray200}}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Selected">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor"
                                    Value="{AppThemeBinding Light={StaticResource LightPrimaryVariant}, Dark={StaticResource DarkPrimaryVariant}}" />
                            <Setter TargetName="FlyoutItemLabel"
                                    Property="Label.TextColor"
                                    Value="{StaticResource White}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
