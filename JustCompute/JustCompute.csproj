  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(TargetFramework)|$(Platform)'=='Release|net10.0-ios|AnyCPU'">
    <CreatePackage>false</CreatePackage>
  </PropertyGroup>
  <!-- ============================================================
       Release-only performance settings
       ============================================================ -->
  <PropertyGroup Condition="'$(Configuration)'=='Release'">
    <Optimize>true</Optimize>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
  <!-- iOS Release: full AOT is mandatory on iOS.
       GeoTimeZone and NodaTime are interpreted instead of AOT-compiled because their AOT modules
       fail to load on Mono with "dependency cannot be found or out of date" — the AOT/trim
       pipeline drops a transitive dependency between them and the runtime can't resolve it.
       Both libraries do one-shot lookups (lat/lon → timezone) on non-hot paths, so the
       interpreter cost is negligible. Everything else stays AOT-compiled. -->
  <PropertyGroup Condition="'$(Configuration)|$(TargetFramework)'=='Release|net10.0-ios'">
    <MtouchInterpreter>GeoTimeZone,NodaTime</MtouchInterpreter>
  </PropertyGroup>
  <!-- LLVM optimizes the native code AOT produces. Applied to both device and simulator —
       once the GeoTimeZone/NodaTime AOT-module-load bug is bypassed by the interpreter
       setting above, LLVM on simulator turned out to be fine in practice. -->
  <PropertyGroup Condition="'$(Configuration)|$(TargetFramework)'=='Release|net10.0-ios'">
    <MtouchUseLlvm>true</MtouchUseLlvm>
  </PropertyGroup>
  
  <!-- Android Release — known-good optimization set.
       EnableLLVM intentionally OFF: with our dependencies (notably AutoMapper + sqlite-net
       reflection-heavy paths), the LLVM optimizer pass mis-compiles something on the
       data-load path and the app aborts shortly after launch. Mono's default AOT alone
       still gives most of the startup-time and steady-state wins; LLVM was diminishing
       returns we couldn't ship. Revisit only if a specific perf measurement justifies it.
       AndroidStripILAfterAOT is safe to enable because mylinker.xml pins preserve="all"
       on app assemblies (Compute.Core, JustCompute.Persistence, AutoMapper), so only
       BCL/MAUI IL bodies get stripped — those assemblies don't need IL at runtime. -->
  <PropertyGroup Condition="'$(Configuration)|$(TargetFramework)'=='Release|net10.0-android36.0'">
    <RunAOTCompilation>true</RunAOTCompilation>
    <EnableLLVM>false</EnableLLVM>
    <AndroidStripILAfterAOT>true</AndroidStripILAfterAOT>
    <AndroidEnableProfiledAot>true</AndroidEnableProfiledAot>
    <AndroidLinkTool>r8</AndroidLinkTool>
  </PropertyGroup>
